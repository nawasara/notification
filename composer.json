{
    "name": "nawasara/notification",
    "description": "Unified outbound notification — multi-channel routing, templates, queue, audit log",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Nawasara\\Notification\\": "src/"
        }
    },
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^12.0",
        "spatie/laravel-permission": "^6.0",
        "nawasara/ui": "*",
        "nawasara/sync": "*",
        "livewire/livewire": "^3.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Nawasara\\Notification\\NotificationServiceProvider"
            ],
            "aliases": {
                "Notify": "Nawasara\\Notification\\Facades\\Notify"
            }
        }
    }
}
