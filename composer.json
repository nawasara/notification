{
    "name": "nawasara/notification",
    "description": "Unified outbound notification for the Nawasara superapp framework — multi-channel routing, Blade templates, queue dispatch, and an audit log of every send.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "nawasara",
        "laravel",
        "notification",
        "email",
        "smtp",
        "template",
        "queue",
        "audit"
    ],
    "authors": [
        {
            "name": "Pringgo J. Saputro",
            "email": "odyinggo@gmail.com",
            "role": "Lead Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/nawasara/notification/issues",
        "source": "https://github.com/nawasara/notification"
    },
    "autoload": {
        "psr-4": {
            "Nawasara\\Notification\\": "src/"
        }
    },
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^12.0",
        "spatie/laravel-permission": "^6.0",
        "nawasara/ui": "*",
        "nawasara/sync": "*",
        "nawasara/vault": "*",
        "livewire/livewire": "^3.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Nawasara\\Notification\\NotificationServiceProvider"
            ],
            "aliases": {
                "Notify": "Nawasara\\Notification\\Facades\\Notify"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
